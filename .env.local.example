# Houston Home Spotlight — Local Environment Variables
# Copy to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.
#
# For Cloudflare Workers local dev, use .dev.vars (also gitignored).
# The values below are also needed in .dev.vars for wrangler dev / cf:preview.

# ─── Perfex CRM ─────────────────────────────────────────────────────────────
PERFEX_RE_URL=https://your-perfex-instance.com
PERFEX_RE_KEY=your-perfex-api-key

# ─── Firebase Client SDK (public — NEXT_PUBLIC_ prefix required) ────────────
# Source: Firebase Console -> Project Settings -> General -> Your apps -> Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── Firebase Service Account (server-side — NEVER expose publicly) ─────────
# Source: Firebase Console -> Project Settings -> Service accounts -> Generate new private key
# In production, set these via: wrangler secret put FIREBASE_PROJECT_ID (etc.)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the full PEM key; wrangler stores with \\n which auth-edge.ts normalizes back to \n
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ─── Session Cookie Signing Keys ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Rotate: move CURRENT to PREVIOUS, generate a new CURRENT
COOKIE_SECRET_CURRENT=your-32-char-base64-secret-here
COOKIE_SECRET_PREVIOUS=your-previous-32-char-base64-secret
