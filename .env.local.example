# Houston Home Spotlight — Local Environment Variables
# Copy to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.
#
# For Cloudflare Workers local dev, use .dev.vars (also gitignored).
# The values below are also needed in .dev.vars for wrangler dev / cf:preview.

# ─── Perfex CRM ─────────────────────────────────────────────────────────────
PERFEX_RE_URL=https://your-perfex-instance.com
PERFEX_RE_KEY=your-perfex-api-key

# ─── Firebase Client SDK (public — NEXT_PUBLIC_ prefix required) ────────────
# Source: Firebase Console -> Project Settings -> General -> Your apps -> Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── Firebase Service Account (server-side — NEVER expose publicly) ─────────
# Source: Firebase Console -> Project Settings -> Service accounts -> Generate new private key
# In production, set these via: wrangler secret put FIREBASE_PROJECT_ID (etc.)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the full PEM key; wrangler stores with \\n which auth-edge.ts normalizes back to \n
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ─── Session Cookie Signing Keys ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Rotate: move CURRENT to PREVIOUS, generate a new CURRENT
COOKIE_SECRET_CURRENT=your-32-char-base64-secret-here
COOKIE_SECRET_PREVIOUS=your-previous-32-char-base64-secret

# ─── Stripe (Phase 3 — subscription billing) ───────────────────────────────
# Source: Stripe Dashboard -> Developers -> API keys -> Secret key (test mode for dev)
# Production: wrangler secret put STRIPE_SECRET_KEY
# Local dev: add to .dev.vars (gitignored) — NOT .env.local (Next.js env vars
#   are not available in the Workers runtime; use CloudflareEnv bindings instead)
STRIPE_SECRET_KEY=sk_test_...

# Source: Stripe Dashboard -> Developers -> Webhooks -> signing secret
# (or output of: stripe listen --forward-to localhost:8787/api/stripe/webhook)
# Production: wrangler secret put STRIPE_WEBHOOK_SECRET
STRIPE_WEBHOOK_SECRET=whsec_...

# Source: Stripe Dashboard -> Product catalog -> create $79/mo recurring Price -> copy price_… id
# Create once: Products -> Add product -> $79/month recurring -> copy Price ID
# Production: wrangler secret put STRIPE_PRICE_ID
STRIPE_PRICE_ID=price_...

# Resend email delivery (Phase 4 — Lead notification)
# RESEND_API_KEY: API key from Resend dashboard (re_xxxxxxxxx)
# LEAD_FROM_EMAIL: Verified sending domain email (e.g. leads@houstonhomespotlight.com)
#   IMPORTANT: The from domain must be DNS-verified in the Resend dashboard before emails deliver.
# ADMIN_NOTIFY_EMAIL: Bernard's email address to CC on all buyer inquiry notifications
RESEND_API_KEY=
LEAD_FROM_EMAIL=
ADMIN_NOTIFY_EMAIL=


# --- AI Video Generation (Phase 6) -----------------------------------------
# Primary video provider: Kie.ai (Kling 2.6 image-to-video)
# Source: https://kie.ai/api-key -- copy the API key from the dashboard
# Production: wrangler secret put KIE_API_KEY
# Local dev: add to .dev.vars (gitignored)
KIE_API_KEY=

# HMAC signing secret for Kie.ai webhook callbacks (strongly recommended).
# Source: https://kie.ai/settings -- set webhookHmacKey; copy the same value here.
# This key signs X-Webhook-Signature on every callback POST to /api/video/callback.
# Without this, the callback route cannot authenticate Kie.ai requests -- do not skip in production.
# Production: wrangler secret put KIE_WEBHOOK_SECRET
KIE_WEBHOOK_SECRET=

# Fallback video provider: HiggsField (dop-turbo image-to-video)
# Source: https://platform.higgsfield.ai -- copy KEY_ID and KEY_SECRET from the console.
# Store as a single KEY_ID:KEY_SECRET string (the adapter prefixes with Key ).
# Production: wrangler secret put HIGGSFIELD_API_KEY
HIGGSFIELD_API_KEY=