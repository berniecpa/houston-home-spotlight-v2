{
  "name": "houston-home-spotlight-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "tsx --test",
    "typecheck": "tsc --noEmit",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && wrangler deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "admin:set-claim": "tsx scripts/set-admin-claim.ts"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "next": "^15.5.19",
    "next-firebase-auth-edge": "^1.12.0",
    "react": "^18",
    "react-dom": "^18",
    "stripe": "^22.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260610.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.27",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "firebase-admin": "^14.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "wrangler": "^4.99.0"
  }
}
